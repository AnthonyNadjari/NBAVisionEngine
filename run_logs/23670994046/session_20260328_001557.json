    },
    {
      "tweet_url": "https://x.com/LawMurrayTheNU/status/2037659176571429076",
      "reply_text": "Kawhi's back on the court, good to see",
      "posted_at": "2026-03-27T23:21:39.586741+00:00"
    },
    {
      "tweet_url": "https://x.com/hoodg3nius/status/2037651453053907097",
      "reply_text": "Trading Giannis for scraps and cash is a non-starter. He's still a top-3 player.",
      "posted_at": "2026-03-27T23:23:05.821040+00:00"
    },
    {
      "tweet_url": "https://x.com/WadexFlash/status/2037657497373450545",
      "reply_text": "That's a great point about their prep. It paid off in the end.",
      "posted_at": "2026-03-27T23:35:53.254482+00:00"
